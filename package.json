{
  "name": "show-me-tokens",
  "version": "0.1.0",
  "description": "CLI and web dashboard for reporting per-session token usage of AI IDE agents",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "show-me-tokens": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "tsx watch src/server.ts --serve --port 3456",
    "dev:web": "vite --config vite.config.ts",
    "build": "npm run clean && npm run build:server && npm run build:web && npm run build:bin",
    "build:server": "tsc -p tsconfig.server.json",
    "build:web": "vite build",
    "build:bin": "chmod +x dist/cli.js dist/server.js",
    "start": "node dist/server.js --serve",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "keywords": [
    "qoder",
    "ai-ide",
    "tokens",
    "cli",
    "dashboard"
  ],
  "author": "lvdeqing",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "commander": "^12.0.0",
    "express": "^4.19.0",
    "open": "^10.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/supertest": "^6.0.2",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^2.12.0",
    "rimraf": "^5.0.7",
    "supertest": "^7.0.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.0",
    "vite": "^5.3.0",
    "vitest": "^1.6.0"
  }
}
